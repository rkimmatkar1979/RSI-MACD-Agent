# Get a free key from https://console.groq.com/keys (or any other
# OpenAI-compatible provider - xAI, OpenRouter, GitHub Models, etc.)
LLM_API_KEY=your_llm_api_key_here

# Defaults below point at Groq's free tier. To use a different provider,
# change LLM_API_URL and LLM_MODEL accordingly - the request/response shape
# must be OpenAI-compatible (chat completions).
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Authentication (Google sign-in)
# ---------------------------------------------------------------------------
# Maximum number of distinct Google accounts allowed to use this app
# (first-come-first-served; admins below are exempt).
AUTH_MAX_USERS=10

# Comma-separated Google account emails that bypass AUTH_MAX_USERS and can
# manage the authorized-user list from the in-app Admin tab.
AUTH_ADMIN_EMAILS=you@example.com

# NOTE: the actual Google OAuth Client ID/Secret and cookie secret go in
# .streamlit/secrets.toml (NOT this file) - see
# .streamlit/secrets.toml.example for the template and setup steps.

# ---------------------------------------------------------------------------
# Persistent database (optional)
# ---------------------------------------------------------------------------
# By default the app stores scans/signals/users in a local SQLite file
# (trading_agent.db), which is fine for local development but gets wiped
# whenever Streamlit Community Cloud restarts/redeploys the app. To persist
# data across restarts, create a free database at https://turso.tech and set
# both of these - leave both blank to keep using local SQLite.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
